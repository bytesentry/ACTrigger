<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="ACTrigger.UI.Views.AboutWindow"
    Title="About ACTrigger"
    Width="400"
    Height="220">

    <StackPanel
        Margin="20"
        Spacing="10">

        <TextBlock
            FontSize="20"
            FontWeight="Bold"
            Text="ACTrigger"/>

        <TextBlock
            Text="Combat triggers and overlays for Asheron's Call."/>

        <Button
            Content="https://github.com/bytesentry"
            Click="GitHub_Click"/>

    </StackPanel>

</Window>